CONFIG_FILE = os.path.join(CONFIG_DIR, "linexin-center.json")

def _load_config() -> Dict[str, Any]:
    """Load app configuration from JSON file."""
    try:
        if os.path.exists(CONFIG_FILE):
            with open(CONFIG_FILE, 'r') as f:
                return json.load(f)
    except Exception:
        pass
    return {}

def _save_config(config):
    """Save app configuration to JSON file."""
    try:
        os.makedirs(CONFIG_DIR, mode=0o700, exist_ok=True)
        with open(CONFIG_FILE, 'w') as f:
            json.dump(config, f, indent=2)
    except Exception as e:
        print(f"Error saving config: {e}")
_original_popen = subprocess.Popen
_original_run = subprocess.run
_original_call = subprocess.call
_original_check_call = subprocess.check_call
_original_check_output = subprocess.check_output
_original_messagedialog_init = Adw.MessageDialog.__init__
_original_messagedialog_set_heading = Adw.MessageDialog.set_heading
_original_messagedialog_set_body = Adw.MessageDialog.set_body
_original_messagedialog_add_response = Adw.MessageDialog.add_response
_original_messagedialog_present = Adw.MessageDialog.present
_original_preferenceswindow_present = Adw.PreferencesWindow.present
def _translate_with_patterns_helper(text, widget_id):
    """
    Helper function to translate text that might contain dynamic variables (placeholders).
    Uses the localization manager to find matches.
    """
    if not text:
        return ""
    translated = _(text, widget_id)
    if translated != text:
        return translated
    patterns_to_translate = [
        "{} updates available",       
        "Updating {}...",
        "Process exited with code {}",
        "Successfully updated your {}!",
        "Installing {}...",
        "Successfully installed {}!",
        "Successfully installed {}",  
        "Successfully removed {}",    
        "Removing {}...",             
        "Removing {}",                
        "Please enter your password to {} this package.", 
        "Please enter your password to {} this package",
        "Building {}...",             
        "Removed {}",                 
        "Installed {}",               
        "Back to Search",             
        "To complete the change to {}, you need to log out and log back in again."
    ]
    for pattern in patterns_to_translate:
        escaped_pattern = re.escape(pattern)
        regex_pattern = escaped_pattern.replace(re.escape("{}"), r"(.*)")
        match = re.search(regex_pattern, text)
        if match:
            translated_pattern = _(pattern, widget_id)
            if translated_pattern != pattern:
                if match.groups():
                    content = match.group(1)
                    translated_content = _translate_with_patterns_helper(content, widget_id)
                    translated_text = translated_pattern.replace("{}", translated_content)
                    return text.replace(match.group(0), translated_text)
                else:
                    return text.replace(match.group(0), translated_pattern)
    return text
def _translated_messagedialog_init(self, **kwargs):
    """MessageDialog.__init__ wrapper that translates initial properties."""
    widget_id = None
    parent = kwargs.get('transient_for')
    if parent and hasattr(parent, 'active_widget_id'):
        widget_id = parent.active_widget_id
    if widget_id:
        if 'heading' in kwargs and kwargs['heading']:
            kwargs['heading'] = _translate_with_patterns_helper(kwargs['heading'], widget_id)
        if 'body' in kwargs and kwargs['body']:
            kwargs['body'] = _translate_with_patterns_helper(kwargs['body'], widget_id)
    _original_messagedialog_init(self, **kwargs)
def _translated_messagedialog_set_heading(self, heading):
    """MessageDialog.set_heading wrapper."""
    widget_id = _resolve_widget_id_from_dialog(self)
    if heading and widget_id:
        heading = _translate_with_patterns_helper(heading, widget_id)
    _original_messagedialog_set_heading(self, heading)
def _translated_messagedialog_set_body(self, body):
    """MessageDialog.set_body wrapper."""
    widget_id = _resolve_widget_id_from_dialog(self)
    if body and widget_id:
        body = _translate_with_patterns_helper(body, widget_id)
    _original_messagedialog_set_body(self, body)
def _translated_messagedialog_add_response(self, response_id, label):
    """MessageDialog.add_response wrapper."""
    widget_id = _resolve_widget_id_from_dialog(self)
    if label and widget_id:
        label = _translate_with_patterns_helper(label, widget_id)
    _original_messagedialog_add_response(self, response_id, label)
def _translated_messagedialog_present(self):
    """
    Wrapper for present() that forces a translation pass on the entire dialog tree.
    This catches:
    1. Widgets added to extra_child (like PasswordEntry, CheckButtons)
    2. Markup that wasn't handled by simple property translation
    """
    widget_id = _resolve_widget_id_from_dialog(self)
    if widget_id:
        win = self.get_transient_for()
        if win and hasattr(win, '_translate_widget_recursive'):
            win._translate_widget_recursive(self, widget_id)
        else:
             pass
    _original_messagedialog_present(self)
def _resolve_widget_id_from_dialog(dialog):
    """Helper to find the active widget ID from a dialog's transient parent."""
    try:
        win = dialog.get_transient_for()
        if win and hasattr(win, 'active_widget_id'):
            return win.active_widget_id
    except:
        pass
    return None
Adw.MessageDialog.__init__ = _translated_messagedialog_init
Adw.MessageDialog.set_heading = _translated_messagedialog_set_heading
Adw.MessageDialog.set_body = _translated_messagedialog_set_body
Adw.MessageDialog.add_response = _translated_messagedialog_add_response
Adw.MessageDialog.present = _translated_messagedialog_present
def _translated_preferenceswindow_present(self):
    """PreferencesWindow.present wrapper that translates all content."""
    widget_id = None
    try:
        win = self.get_transient_for()
        if win and hasattr(win, 'active_widget_id'):
            widget_id = win.active_widget_id
    except Exception:
        pass
    if widget_id:
        win = self.get_transient_for()
        if win and hasattr(win, '_translate_widget_recursive'):
            win._translate_widget_recursive(self, widget_id)
    _original_preferenceswindow_present(self)
Adw.PreferencesWindow.present = _translated_preferenceswindow_present
_global_lock_manager = None
def _get_lock_manager():
    """Get the global lock manager instance."""
    return _global_lock_manager
class _LockedPopen(_original_popen):
    """Subprocess.Popen wrapper that handles UI locking."""
    def __init__(self, *args, **kwargs):
        lock_manager = _get_lock_manager()
        if lock_manager:
            lock_manager.lock()
        super().__init__(*args, **kwargs)
        if lock_manager:
            def monitor():
                try:
                    self.wait()
                finally:
                    if lock_manager is not None:
                        lock_manager.unlock()
            thread = threading.Thread(target=monitor, daemon=True)
            thread.start()
def _locked_run(*args, **kwargs):
    """Subprocess.run wrapper with locking."""
    lock_manager = _get_lock_manager()
    if lock_manager:
        lock_manager.lock()
    try:
        return _original_run(*args, **kwargs) # type: ignore
    finally:
        if lock_manager:
            lock_manager.unlock()
def _locked_call(*args, **kwargs):
    """Subprocess.call wrapper with locking."""
    lock_manager = _get_lock_manager()
    if lock_manager:
        lock_manager.lock()
    try:
        return _original_call(*args, **kwargs) # type: ignore
    finally:
        if lock_manager:
            lock_manager.unlock()
def _locked_check_call(*args, **kwargs):
    """Subprocess.check_call wrapper with locking."""
    lock_manager = _get_lock_manager()
    if lock_manager:
        lock_manager.lock()
    try:
        return _original_check_call(*args, **kwargs) # type: ignore
    finally:
        if lock_manager:
            lock_manager.unlock()
def _locked_check_output(*args, **kwargs):
    """Subprocess.check_output wrapper with locking."""
    lock_manager = _get_lock_manager()
    if lock_manager:
        lock_manager.lock()
    try:
        return _original_check_output(*args, **kwargs) # type: ignore
    finally:
        if lock_manager:
            lock_manager.unlock()
subprocess.Popen = _LockedPopen # type: ignore
subprocess.run = _locked_run # type: ignore
subprocess.call = _locked_call # type: ignore
subprocess.check_call = _locked_check_call # type: ignore
subprocess.check_output = _locked_check_output # type: ignore
class WidgetLocalizationManager(GObject.Object):
    """
    Manages translations for widgets using system locale.
    Loads translations from organized directory structure.
    """
    __gtype_name__ = 'WidgetLocalizationManager'
    _instance = None
    def __new__(cls):
        if cls._instance is None:
            cls._instance = super().__new__(cls) # pylint: disable=no-value-for-parameter
            cls._instance._initialized = False
        return cls._instance
    def __init__(self):
        if getattr(self, '_initialized', False):
            return
        super().__init__()
        self.system_language: str = str(self._get_system_language())
        print(f"System language detected: {self.system_language}")
        self.widget_translations: Dict[str, Dict[str, Dict[str, str]]] = {}
        self._load_all_translations()
        print(f"DEBUG: Loaded translations for widgets: {list(self.widget_translations.keys())}")
        if 'system_updater' in self.widget_translations:
             print(f"DEBUG: system_updater languages: {list(self.widget_translations['system_updater'].keys())}")
        self._initialized: bool = True
        self.selection_timeout_id: Optional[int] = None
        self.pending_widget_selection: Any = None
    def _get_system_language(self):
        """Get the system language code."""
        try:
            lang = locale.getlocale()[0]
            if lang:
                lang_code = lang.split('.')[0]
                return lang_code
        except:
            pass
        lang_env = os.environ.get('LANG', '')
        if lang_env:
            lang_code_env: str = lang_env.split('.')[0]
            if lang_code_env:
                return lang_code_env
        return FALLBACK_LANGUAGE
    def _load_all_translations(self):
        """Load all available translations from the directory structure."""
        localization_dir = Path(LOCALIZATION_BASE_DIR)
        if not localization_dir.exists():
            print(f"Localization directory does not exist: {LOCALIZATION_BASE_DIR}")
            return
        for lang_dir in localization_dir.iterdir():
            if not lang_dir.is_dir():
                continue
            language_code = lang_dir.name
            for dict_file in lang_dir.glob("*_dictionary.py"):
                widget_name = dict_file.stem.replace("_dictionary", "")
                self._load_translation_file(widget_name, language_code, dict_file)
    def _load_translation_file(self, widget_name, language_code, file_path):
        """Load a single translation dictionary file."""
        try:
            spec = importlib.util.spec_from_file_location(
                f"{widget_name}_{language_code}_dict", 
                file_path
            )
            if spec is None:
                return
            loader = spec.loader
            if loader is None:
                return
            module = importlib.util.module_from_spec(spec)
            loader.exec_module(module)
            if hasattr(module, 'translations'):
                if widget_name not in self.widget_translations:
                    self.widget_translations[widget_name] = {}
                self.widget_translations[widget_name][language_code] = module.translations
        except Exception:
            pass
    def get_text(self, key, widget_name="widget_loader"):
        """
        Get translated text for a key.
        """
        if widget_name in self.widget_translations:
            widget_trans = self.widget_translations[widget_name]
            if self.system_language in widget_trans:
                if key in widget_trans[self.system_language]:
                    translated = widget_trans[self.system_language][key]
                    return translated
            if FALLBACK_LANGUAGE in widget_trans:
                if key in widget_trans[FALLBACK_LANGUAGE]:
                    return widget_trans[FALLBACK_LANGUAGE][key]
        return key
_localization_manager = None
class CommandLockManager:
    """Manages UI locking during command execution."""
    def __init__(self):
        self.is_locked = False
        self.lock_count = 0  
        self.window_ref = None
        self._lock = threading.Lock()
    def set_window(self, window):
        """Set reference to main window."""
        self.window_ref = window
    def lock(self):
        """Lock the UI."""
        with self._lock:
            self.lock_count += 1
            if not self.is_locked:
                self.is_locked = True
                if self.window_ref is not None:
                    GLib.idle_add(self.window_ref._apply_command_lock, True) # type: ignore
    def unlock(self):
        """Unlock the UI."""
        with self._lock:
            self.lock_count = max(0, self.lock_count - 1)
            if self.lock_count == 0 and self.is_locked:
                self.is_locked = False
                if self.window_ref is not None:
                    GLib.idle_add(self.window_ref._apply_command_lock, False) # type: ignore
def get_localization_manager():
    """Get the singleton localization manager."""
    global _localization_manager
    if _localization_manager is None:
        _localization_manager = WidgetLocalizationManager()
    return _localization_manager
def _(key, widget_name="widget_loader"):
    """Convenience function for translations."""
    return get_localization_manager().get_text(key, widget_name)
class WidgetLoaderWindow(Adw.ApplicationWindow):
    """Main application window with sidebar and content area."""
    def __init__(self, *args: Any, hide_sidebar: bool=False, target_widget: Optional[str]=None, voice_autostart: bool=False, conversation_id: Optional[str]=None, **kwargs: Any) -> None:
        super().__init__(*args, **kwargs)
        self.hide_sidebar: bool = hide_sidebar
        self.target_widget: Optional[str] = target_widget
        self.voice_autostart: bool = voice_autostart
        self.conversation_id: Optional[str] = conversation_id
        self.l10n = get_localization_manager()
        self.set_title(_("Linexin Center"))
        if self.hide_sidebar:
            self.set_default_size(800, 600)
        else:
            self.set_default_size(1280, 730)
        self.loaded_widgets: Dict[str, Any] = {}      
        self.widget_metadata: Dict[str, Dict[str, Any]] = {}     
        self.widget_order: list[str] = []          
        self.widget_index: Dict[str, int] = {}          
        self._visible_widget_name: Optional[str] = None  
        self.active_widget: Any = None
        self.active_widget_id: Optional[str] = None
        self.translation_timer: Optional[int] = None
        self.first_widget_loaded: bool = False
        self.selection_timeout_id: Optional[int] = None
        self.pending_widget_selection: Any = None
        self._compact_mode: bool = False
        self._saved_compact: bool = bool(_load_config().get("compact_mode", False))
        self._edit_mode: bool = False
        self._hidden_widgets: set = set(_load_config().get("hidden_widgets", []))
        self._sidebar_rows: list[Any] = []
        self._compact_icon_buttons: list[Any] = []
        self._edit_suffix_widgets: Dict[str, list] = {}
        self._sidebar_anim: Optional[Adw.TimedAnimation] = None
        self._btn_rotate_anim: Optional[Adw.TimedAnimation] = None
        self._btn_rotation_deg = 180.0
        global _global_lock_manager
        _global_lock_manager = CommandLockManager()
        _global_lock_manager.set_window(self)
        self.command_lock_manager = _global_lock_manager
        self.is_command_locked = False
        self._setup_button_layout_monitoring()
        self._build_ui()
        if self.hide_sidebar and self.target_widget:
            GLib.timeout_add(50, self._staged_load_step1)
        else:
            self._load_all_widgets()
        # Apply saved compact mode after UI is built
        if not self.hide_sidebar and self._saved_compact:
            GLib.idle_add(self._apply_saved_compact)
    def resize_window(self, width, height):
        """Custom resize method that tries different approaches"""
        try:
            self.set_default_size(width, height)
            self.set_size_request(width, height)
            print(f"Window resize to {width}x{height} attempted")
            return True
        except Exception as e:
            print(f"Window resize failed: {e}")
            return False
    def resize_and_center(self, width, height):
        """Resize window and attempt to center it"""
        try:
            self.set_default_size(width, height)
            self.set_size_request(width, height)
            self.set_modal(True)  
            GLib.timeout_add(100, lambda: self.set_modal(False))  
            print(f"Window resize to {width}x{height} attempted")
            return True
        except Exception as e:
            print(f"Window resize failed: {e}")
            return False
    def _apply_command_lock(self, locked):
        """Apply or remove command execution lock."""
        self.is_command_locked = locked
        self.widget_list.set_sensitive(not locked)
        if hasattr(self, 'sidebar_page') and not self.hide_sidebar:
            sidebar_header = self.sidebar_container.get_first_child()
            if sidebar_header and isinstance(sidebar_header, Gtk.HeaderBar):
                self._set_window_controls_disabled(sidebar_header, locked)
        if hasattr(self, 'content_header'):
            self._set_window_controls_disabled(self.content_header, locked)
        if hasattr(self, 'split_view') and hasattr(self.split_view, 'set_show_content'):
            self.split_view.set_show_content(not locked)
        if locked:
            self._block_wm_close()
        else:
            self._unblock_wm_close()
    def _set_window_controls_disabled(self, header, disabled):
        """Set window controls in a header bar to invisible+non-interactive (keeping allocation) or restore them."""
        for wc in self._find_window_controls(header):
            wc.set_opacity(0.0 if disabled else 1.0)
            wc.set_can_target(not disabled)

    def _find_window_controls(self, widget):
        """Recursively find all GtkWindowControls descendants of a widget."""
        results = []
        child = widget.get_first_child()
        while child:
            if isinstance(child, Gtk.WindowControls):
                results.append(child)
            results.extend(self._find_window_controls(child))
            child = child.get_next_sibling()
        return results
    def _block_wm_close(self):
        """Block window manager close actions."""
        if not hasattr(self, '_delete_handler_id'):
            self._delete_handler_id = self.connect('close-request', self._block_close_signal)
    def _unblock_wm_close(self):
        """Restore normal window manager close behavior."""
        if hasattr(self, '_delete_handler_id'):
            self.disconnect(self._delete_handler_id)
            delattr(self, '_delete_handler_id')
    def _block_close_signal(self, window):
        """Signal handler that blocks all close attempts."""
        return True  
    def _setup_button_layout_monitoring(self):
        """Monitor GNOME settings for window button layout changes."""
        self.gnome_settings = Gio.Settings.new("org.gnome.desktop.wm.preferences")
        self.current_button_layout = self.gnome_settings.get_string("button-layout")
        self.gnome_settings.connect(
            "changed::button-layout", 
            self._on_button_layout_changed
        )
    def _build_ui(self):
        """Build the main user interface structure."""
        self._create_persistent_widgets()
        if self.hide_sidebar:
            self._build_content_area()
            self.set_content(self.content_page)
            self.set_resizable(True)
        else:
            self._build_sidebar()
            self._build_content_area()
            self.split_view = Adw.NavigationSplitView()
            self.split_view.set_min_sidebar_width(SIDEBAR_WIDTH)
            self.split_view.set_max_sidebar_width(SIDEBAR_WIDTH)
            self.split_view.set_sidebar_width_fraction(0.25)
            self.split_view.set_sidebar(self.sidebar_page)
            self.split_view.set_content(self.content_page)
            self.set_content(self.split_view)
        self._apply_styling()
    def _create_persistent_widgets(self):
        """Create widgets that persist across UI rebuilds."""
        self.widget_stack = Gtk.Stack()
        self.widget_stack.set_transition_type(Gtk.StackTransitionType.SLIDE_UP_DOWN)
        self.widget_stack.set_transition_duration(300)  
        self.widget_stack.set_hexpand(True)
        self.widget_stack.set_vexpand(True)
        if self.hide_sidebar and self.target_widget:
            loading_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
            loading_box.set_valign(Gtk.Align.CENTER)
            loading_box.set_halign(Gtk.Align.CENTER)
            loading_spinner = Gtk.Spinner()
            loading_spinner.set_size_request(32, 32)
            loading_spinner.start()
            loading_box.append(loading_spinner)
            loading_label = Gtk.Label(label=_("Loading..."))
            loading_label.add_css_class("dim-label")
            loading_box.append(loading_label)
            loading_box.set_vexpand(True)
            loading_box.set_hexpand(True)
            self.widget_stack.add_named(loading_box, "placeholder")
        else:
            placeholder = Gtk.Label(label=_("Select a widget from the sidebar"))
            placeholder.set_vexpand(True)
            placeholder.set_hexpand(True)
            self.widget_stack.add_named(placeholder, "placeholder")
        self.widget_stack.set_visible_child_name("placeholder")
        self.content_display = Adw.Bin()
        self.content_display.set_hexpand(True)
        self.content_display.set_vexpand(True)
        self.content_display.set_child(self.widget_stack)
        self.widget_list = Gtk.ListBox()
        self.widget_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.widget_list.add_css_class("navigation-sidebar")
        self.widget_list.connect("row-activated", self._on_widget_selected)
    def _build_sidebar(self):
        """Build the sidebar with widget list and optional window controls."""
        self.sidebar_page = Adw.NavigationPage()
        self.sidebar_page.set_title(_("Widgets"))
        self.sidebar_container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.sidebar_container.set_spacing(0)
        self.sidebar_container.set_hexpand(True)
        header = self._create_sidebar_header()
        self.sidebar_container.append(header)
        separator = self._create_invisible_separator()
        self.sidebar_container.append(separator)
        scrollable_area = self._create_scrollable_widget_list()
        self.sidebar_container.append(scrollable_area)
        # Compact mode icon strip (initially hidden)
        self._compact_strip = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self._compact_strip.set_halign(Gtk.Align.CENTER)
        self._compact_strip.set_valign(Gtk.Align.START)
        self._compact_strip.set_vexpand(True)
        self._compact_strip.set_visible(False)
        self._compact_strip.set_margin_top(6)
        self._compact_strip.set_margin_bottom(6)
        compact_scroll = Gtk.ScrolledWindow()
        compact_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        compact_scroll.set_vexpand(True)
        compact_scroll.set_child(self._compact_strip)
        self.sidebar_container.append(compact_scroll)
        self._compact_scroll = compact_scroll
        self._compact_scroll.set_visible(False)
        # Bottom button bar: Edit + Compact toggle
        self._sidebar_bottom_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._sidebar_bottom_box.set_halign(Gtk.Align.CENTER)
        self._sidebar_bottom_box.set_margin_bottom(16)
        self._sidebar_bottom_box.set_margin_top(4)

        # Edit mode toggle button
        self._edit_toggle_btn = Gtk.Button()
        self._edit_toggle_btn.set_icon_name("document-edit-symbolic")
        self._edit_toggle_btn.add_css_class("flat")
        self._edit_toggle_btn.add_css_class("edit-toggle-btn")
        self._edit_toggle_btn.set_tooltip_text(_("Edit widgets"))
        self._edit_toggle_btn.connect("clicked", self._on_edit_toggle_clicked)
        self._sidebar_bottom_box.append(self._edit_toggle_btn)

        # Compact mode toggle button
        self._compact_toggle_btn = Gtk.Button()
        self._compact_toggle_btn.set_icon_name("sidebar-show-symbolic")
        self._compact_toggle_btn.add_css_class("flat")
        self._compact_toggle_btn.add_css_class("compact-toggle-btn")
        self._compact_toggle_btn.set_tooltip_text(_("Toggle compact mode"))
        self._compact_toggle_btn.connect("clicked", self._on_compact_toggle_clicked)
        self._sidebar_bottom_box.append(self._compact_toggle_btn)
        # Apply initial rotation CSS (180 degrees for normal mode)
        self._btn_css_provider = Gtk.CssProvider()
        self._btn_css_provider.load_from_data(b".compact-toggle-btn { transition: none; transform: rotate(180deg); }")
        self._compact_toggle_btn.get_style_context().add_provider(
            self._btn_css_provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION + 1
        )
        self.sidebar_container.append(self._sidebar_bottom_box)
        self._setup_sidebar_context_menu()
        self.sidebar_page.set_child(self.sidebar_container)
    def _setup_sidebar_context_menu(self):
        menu = Gio.Menu()
        item = Gio.MenuItem.new(_("Create a shortcut"), "win.create_shortcut")
        menu.append_item(item)
        
        self.sidebar_popover = Gtk.PopoverMenu.new_from_model(menu)
        self.sidebar_popover.set_parent(self.widget_list)
        self.sidebar_popover.set_has_arrow(False)
        
        action = Gio.SimpleAction.new("create_shortcut", None)
        action.connect("activate", self._on_create_shortcut)
        self.add_action(action)
        
        action_remove = Gio.SimpleAction.new("remove_shortcut", None)
        action_remove.connect("activate", self._on_remove_shortcut)
        self.add_action(action_remove)
        
        gesture = Gtk.GestureClick()
        gesture.set_button(3)
        gesture.connect("pressed", self._on_sidebar_right_click)
        self.widget_list.add_controller(gesture)

    def _on_sidebar_right_click(self, gesture, n_press, x, y):
        row = self.widget_list.get_row_at_y(y)
        if not row:
            return
        self._context_menu_row = row
        
        # Check if shortcut exists to determine menu item
        widget_name = getattr(row, 'widget_name', '')
        metadata = self.widget_metadata.get(widget_name, {})
        filename = metadata.get('filename', widget_name)
        clean_name = os.path.splitext(filename)[0]
        target_path = f"/usr/share/applications/{clean_name}.desktop"
        
        menu = Gio.Menu()
        if os.path.exists(target_path):
            menu.append(_("Remove shortcut"), "win.remove_shortcut")
        else:
            menu.append(_("Create a shortcut"), "win.create_shortcut")
            
        self.sidebar_popover.set_menu_model(menu)
        
        rect = Gdk.Rectangle()
        rect.x = int(x)
        rect.y = int(y)
        rect.width = 1
        rect.height = 1
        self.sidebar_popover.set_pointing_to(rect)
        self.sidebar_popover.set_position(Gtk.PositionType.BOTTOM)
        self.sidebar_popover.popup()

    def _on_create_shortcut(self, action, param):
        if not hasattr(self, '_context_menu_row') or not self._context_menu_row:
            return
            
        row = self._context_menu_row
        widget_name = getattr(row, 'widget_name', None)
        if not widget_name: return
        
        # Check password first
        manager = get_sudo_manager()
        if not manager.user_password:
            self._prompt_for_password_dialog(lambda: self._perform_shortcut_creation(widget_name), _("Please enter your password to create the shortcut."))
        else:
            self._perform_shortcut_creation(widget_name)

    def _on_remove_shortcut(self, action, param):
        if not hasattr(self, '_context_menu_row') or not self._context_menu_row:
            return
        row = self._context_menu_row
        widget_name = getattr(row, 'widget_name', None)
        if not widget_name: return
        
        manager = get_sudo_manager()
        if not manager.user_password:
            self._prompt_for_password_dialog(lambda: self._perform_shortcut_removal(widget_name), _("Please enter your password to remove the shortcut."))
        else:
            self._perform_shortcut_removal(widget_name)

    def _prompt_for_password_dialog(self, success_callback, message):
        """Prompt for password custom dialog."""
        dialog = Adw.MessageDialog(
            transient_for=self,
            heading=_("Authentication Required"),
            body=message
        )
        dialog.add_response("cancel", _("Cancel"))
        dialog.add_response("authenticate", _("Authenticate"))
        
        # Add password entry
        # Adw.MessageDialog extra child is the way
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        entry = Gtk.PasswordEntry()
        box.append(entry)
        dialog.set_extra_child(box)
        
        def response_handler(dlg, response):
            if response == "authenticate":
                password = entry.get_text()
                manager = get_sudo_manager()
                if manager.validate_password(password):
                    manager.set_password(password)
                    success_callback()
                else:
                    err_dlg = Adw.MessageDialog(
                        transient_for=self,
                        heading=_("Authentication Failed"),
                        body=_("Incorrect password.")
                    )
                    err_dlg.add_response("ok", _("OK"))
                    err_dlg.present()
        
        dialog.connect("response", response_handler)
        dialog.set_default_response("authenticate")
        dialog.present()

    def _perform_shortcut_creation(self, widget_name):
        metadata = self.widget_metadata.get(widget_name, {})
        filename = metadata.get('filename', widget_name)
        widget_id = metadata.get('widget_id',  widget_name.lower().replace(' ', '_'))
        clean_name = os.path.splitext(filename)[0]
        
        # Use translated name
        display_name = _(widget_name, widget_id)
        
        icon_path = metadata.get('icon_path', '')
        if icon_path and not icon_path.startswith('/'):
             icon_path = f"/usr/share/icons/{icon_path}"
             
        content = f"""[Desktop Entry]
Name={display_name}
Exec=linexin-center -w {clean_name}
Icon={icon_path}
Terminal=false
Type=Application
Categories=Utility;Tools;
StartupNotify=false
Hidden=false
"""
        try:
            with tempfile.NamedTemporaryFile(mode='w', delete=False) as tmp:
                tmp.write(content)
                tmp_path = tmp.name
            
            desktop_filename = f"{clean_name}.desktop"
            target_path = f"/usr/share/applications/{desktop_filename}"
            
            manager = get_sudo_manager()
            # Use sudo manager wrapper to execute mv via secure gate
            manager.run_privileged(["mv", tmp_path, target_path], check=True)
            
            dlg = Adw.MessageDialog(
                transient_for=self,
                heading=_("Shortcut Created"),
                body=_("Successfully created shortcut for {}").format(display_name)
            )
            dlg.add_response("ok", _("OK"))
            dlg.present()
            
        except Exception as e:
            print(f"Error creating shortcut: {e}")
            dlg = Adw.MessageDialog(
                transient_for=self,
                heading=_("Error"),
                body=str(e)
            )
            dlg.add_response("ok", _("OK"))
            dlg.present()
        finally:
            get_sudo_manager().forget_password()
    def _perform_shortcut_removal(self, widget_name):
        metadata = self.widget_metadata.get(widget_name, {})
        filename = metadata.get('filename', widget_name)
        widget_id = metadata.get('widget_id',  widget_name.lower().replace(' ', '_'))
        clean_name = os.path.splitext(filename)[0]
        # Use translated name for success message
        display_name = _(widget_name, widget_id)
        
        target_path = f"/usr/share/applications/{clean_name}.desktop"
        
        try:
            if not os.path.exists(target_path):
                 return

            manager = get_sudo_manager()
            manager.run_privileged(["rm", "-f", target_path], check=True)
            
            dlg = Adw.MessageDialog(
                transient_for=self,
                heading=_("Shortcut Removed"),
                body=_("Successfully removed shortcut for {}").format(display_name)
            )
            dlg.add_response("ok", _("OK"))
            dlg.present()
        except Exception as e:
            print(f"Error removing shortcut: {e}")
            dlg = Adw.MessageDialog(
                transient_for=self,
                heading=_("Error"),
                body=str(e)
            )
            dlg.add_response("ok", _("OK"))
            dlg.present()
        finally:
            get_sudo_manager().forget_password()

    def _create_sidebar_header(self):
        """Create sidebar header with title and optional window controls."""
        header = Gtk.HeaderBar()
        header.add_css_class("flat")
        title = Gtk.Label(label=_("Linexin Center"))
        title.add_css_class("heading")
        self._sidebar_header_title = title
        header.set_title_widget(title)
        left_buttons, right_buttons = self._parse_button_layout()
        if left_buttons:
            header.set_show_title_buttons(True)
            header.set_decoration_layout(f"{left_buttons}:")
            title.set_margin_top(0)
            title.set_margin_start(30)
        else:
            header.set_show_title_buttons(False)
            title.set_margin_top(10)
        return header
    def _create_scrollable_widget_list(self):
        """Create scrollable container for the widget list."""
        scrolled_window = Gtk.ScrolledWindow()
        scrolled_window.set_policy(
            Gtk.PolicyType.NEVER,     
            Gtk.PolicyType.AUTOMATIC   
        )
        scrolled_window.set_hexpand(False)
        scrolled_window.set_vexpand(True)
        scrolled_window.set_child(self.widget_list)
        container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        container.set_margin_top(6)
        container.set_margin_bottom(6)
        container.set_margin_start(6)
        container.set_margin_end(6)
        container.append(scrolled_window)
        self._widget_list_container = container
        return container
    def _build_content_area(self):
        """Build the content area with draggable header and widget display."""
        self.content_page = Adw.NavigationPage()
        self.content_page.set_title(_("Widget Content"))
        content_container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content_container.set_spacing(0)
        header = self._create_content_header()
        content_container.append(header)
        separator = self._create_invisible_separator()
        content_container.append(separator)
        content_container.append(self.content_display)
        self.content_page.set_child(content_container)
    def _create_content_header(self):
        """Create content area header (always present for dragging)."""
        header = Gtk.HeaderBar()
        header.add_css_class("flat")
        self.content_header = header
        self._widget_header_widget = None
        if self.hide_sidebar:
            header.set_show_title_buttons(True)
            header.set_decoration_layout(self.current_button_layout)
        else:
            left_buttons, right_buttons = self._parse_button_layout()
            if right_buttons:
                header.set_show_title_buttons(True)
                header.set_decoration_layout(f":{right_buttons}")
            else:
                header.set_show_title_buttons(False)
        header.set_title_widget(Gtk.Label(label=""))
        return header
    def _create_invisible_separator(self):
        """Create a separator with opacity 0."""
        separator = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        separator.add_css_class("hidden-separator")
        return separator
    def _load_all_widgets(self):
        """Load widgets - either all widgets or just the target widget."""
        if not os.path.exists(WIDGET_DIRECTORY):
            if not self.hide_sidebar:
                self._show_error_in_list(
                    _("No widgets found"),
                    _("Directory does not exist").replace("Directory", WIDGET_DIRECTORY)
                )
            return
        if self.hide_sidebar and self.target_widget:
            self._load_target_widget_only()
        else:
            self._load_all_widgets_normal()
        if self.hide_sidebar and self.target_widget:
            self._select_target_widget()
        elif not self.hide_sidebar:
            self._auto_select_first_widget()
    def _staged_load_step1(self) -> bool:
        """Stage 1: Find target file, then load module in a background thread."""
        target_w = self.target_widget
        if not target_w:
            return False
        target_normalized = target_w.lower().replace('-', '_').replace(' ', '_')
        if not target_normalized.endswith('.py'):
            target_normalized += '.py'
        if not os.path.exists(WIDGET_DIRECTORY):
            return False
        python_files = [f for f in os.listdir(WIDGET_DIRECTORY) if f.endswith(".py")]
        target_file: Optional[str] = None
        for filename in python_files:
            filename_normalized = filename.lower().replace('-', '_').replace(' ', '_')
            if (filename_normalized == target_normalized or
                filename.lower() == target_w.lower() or
                filename.lower() == target_w.lower() + '.py'):
                target_file = filename
                break
        if target_file is None:
            print(f"Target widget file not found: {self.target_widget}")
            return False
        target_filepath: str = os.path.join(WIDGET_DIRECTORY, str(target_file))
        target_module_name: str = str(target_file).replace('.py', '')
        print(f"Loading target widget (threaded): {target_file}")
        # Run the heavy exec_module in a background thread so the GTK main
        # loop keeps processing redraws (spinner) and input (close button).
        def _bg_import() -> None:
            try:
                spec = importlib.util.spec_from_file_location(
                    target_module_name, target_filepath
                )
                if spec is None:
                    return
                # Safely bind the non-None loader because Pyre forgets the `spec is None` guarantee
                active_loader: Any = getattr(spec, 'loader', None)
                if active_loader is None:
                    return
                module = importlib.util.module_from_spec(spec)
                if hasattr(active_loader, 'exec_module'):
                    loader_func: Any = getattr(active_loader, 'exec_module')
                    loader_func(module)
                # Return to main thread for GTK widget creation
                GLib.idle_add(self._staged_load_step2, module,
                              target_module_name, target_filepath)
            except Exception:
                traceback.print_exc()
        thread = threading.Thread(target=_bg_import, daemon=True)
        thread.start()
        return False
    def _staged_load_step2(self, module, module_name, filepath):
        """Stage 2: Prepare module and create widget (main thread)."""
        try:
            module, filename = self._prepare_module(module, module_name, filepath)
            # Flush pending events so spinner redraws before widget creation
            ctx = GLib.MainContext.default()
            while ctx.pending():
                ctx.iteration(False)
            self._extract_widgets_from_module(module, filename)
            # Flush again after widget creation
            while ctx.pending():
                ctx.iteration(False)
            self._select_target_widget()
        except Exception:
            traceback.print_exc()
        return False
    def _load_all_widgets_normal(self):
        """Load all widgets (normal mode)."""
        python_files = [f for f in os.listdir(WIDGET_DIRECTORY) if f.endswith(".py")]

        # Load saved widget order from config
        config = _load_config()
        saved_order = config.get("widget_order", [])

        if saved_order:
            # Use saved order for known widgets; new widgets sorted by date at end
            known_files = [f for f in saved_order if f in python_files]
            new_files = [f for f in python_files if f not in saved_order]
            new_files.sort(key=lambda f: os.path.getmtime(os.path.join(WIDGET_DIRECTORY, f)))
            python_files = known_files + new_files
        else:
            # No saved order — sort by date added (modification time)
            python_files.sort(key=lambda f: os.path.getmtime(os.path.join(WIDGET_DIRECTORY, f)))
        for filename in python_files:
            filepath: str = os.path.join(WIDGET_DIRECTORY, filename)
            module_name: str = filename[:-3] # type: ignore
            self._load_widget_from_file(filepath, module_name)
    def refresh_widgets(self):
        """Re-scan the widgets directory and load any new widget files."""
        if not os.path.exists(WIDGET_DIRECTORY):
            return
        # Collect filenames already loaded
        loaded_filenames = set()
        for meta in self.widget_metadata.values():
            loaded_filenames.add(meta.get('filename', ''))
        python_files = [f for f in os.listdir(WIDGET_DIRECTORY) if f.endswith(".py")]
        new_files = [f for f in python_files if f not in loaded_filenames]
        if not new_files:
            return
        new_files.sort(key=lambda f: os.path.getmtime(os.path.join(WIDGET_DIRECTORY, f)))
        for filename in new_files:
            filepath = os.path.join(WIDGET_DIRECTORY, filename)
            module_name = filename[:-3]
            self._load_widget_from_file(filepath, module_name)
    def _load_target_widget_only(self):
        """Load only the target widget specified via command line."""
        target_w = self.target_widget
        if not target_w:
            return
        target_normalized = target_w.lower().replace('-', '_').replace(' ', '_')
        if not target_normalized.endswith('.py'):
            target_normalized += '.py'
        if not os.path.exists(WIDGET_DIRECTORY):
            return
        python_files = [f for f in os.listdir(WIDGET_DIRECTORY) if f.endswith(".py")]
        target_file: Optional[str] = None
        for filename in python_files:
            filename_normalized = filename.lower().replace('-', '_').replace(' ', '_')
            if (filename_normalized == target_normalized or 
                filename.lower() == target_w.lower() or
                filename.lower() == target_w.lower() + '.py'):
                target_file = filename
                break
        if target_file and isinstance(target_file, str):
            filepath: str = os.path.join(WIDGET_DIRECTORY, target_file)
            module_name: str = target_file[:-3] # type: ignore
            print(f"Loading only target widget: {target_file}")
            self._load_widget_from_file(filepath, module_name)
        else:
            print(f"Target widget file not found: {self.target_widget}")
    def _select_target_widget(self):
        """Select the target widget specified via command line."""
        if not self.widget_metadata:
            print(f"No widgets loaded for target: {self.target_widget}")
            error_label = Gtk.Label(label=f"Widget '{self.target_widget}' not found or failed to load")
            error_label.set_vexpand(True)
            error_label.set_hexpand(True)
            error_label.add_css_class("dim-label")
            self.widget_stack.add_named(error_label, "error")
            self.widget_stack.set_visible_child_name("error")
            return
        widget_name = list(self.widget_metadata.keys())[0]
        print(f"Loading single widget: {widget_name}")
        self._load_single_widget_mode(widget_name)
    def _load_single_widget_mode(self, widget_name):
        """Load a single widget in fullscreen mode (no sidebar)."""
        if widget_name not in self.loaded_widgets:
            return
        widget_instance = self.loaded_widgets[widget_name]
        self.active_widget = widget_instance
        self.active_widget_id = self.widget_metadata.get(widget_name, {}).get('widget_id')
        GLib.idle_add(self.update_widget_header)
        filename = self.widget_metadata.get(widget_name, {}).get('filename', widget_name)
        stack_page_name = self._generate_stack_page_name(filename)
        self._add_widget_to_stack(widget_instance, widget_name, stack_page_name)
        transition = None
        prev_name = getattr(self, '_visible_widget_name', None)
        if prev_name and prev_name in self.widget_index and widget_name in self.widget_index:
            prev_idx = self.widget_index[prev_name]
            curr_idx = self.widget_index[widget_name]
            if curr_idx > prev_idx:
                transition = Gtk.StackTransitionType.SLIDE_DOWN
            elif curr_idx < prev_idx:
                transition = Gtk.StackTransitionType.SLIDE_UP
        if transition is not None:
            self.widget_stack.set_visible_child_full(stack_page_name, transition)
        else:
            self.widget_stack.set_visible_child_name(stack_page_name)
        self._visible_widget_name = widget_name
        display_name = _(widget_name, self.active_widget_id) if self.active_widget_id else widget_name
        self.set_title(display_name)
        self.content_page.set_title(display_name)
        # Defer expensive recursive tree walks so widget appears immediately
        if self.active_widget_id and isinstance(widget_instance, Gtk.Widget):
            GLib.idle_add(self._deferred_translation_setup, widget_instance, self.active_widget_id)
    def _deferred_translation_setup(self, widget_instance, widget_id):
        """Run translation and signal setup after the widget is visible."""
        self._translate_widget_content(widget_instance, widget_id)
        self._connect_widget_signals(widget_instance, widget_id)
        self._start_translation_monitoring()
        return False
    def update_widget_header(self):
        """Update header bar with widget-specific controls on opposite side of window controls."""
        if not self.hide_sidebar or not hasattr(self, 'content_header'):
            return
        if hasattr(self, '_widget_header_widget') and self._widget_header_widget:
            self.content_header.remove(self._widget_header_widget)
            self._widget_header_widget = None
        if hasattr(self, 'active_widget') and self.active_widget:
            if hasattr(self.active_widget, 'get_header_bar_widget'):
                try:
                    widget_header_widget = self.active_widget.get_header_bar_widget()
                    if widget_header_widget:
                        left_buttons, right_buttons = self._parse_button_layout()
                        if left_buttons:
                            self.content_header.pack_end(widget_header_widget)
                        else:
                            self.content_header.pack_start(widget_header_widget)
                        self._widget_header_widget = widget_header_widget
                except Exception as e:
                    print(f"Error adding widget header controls: {e}")
    def _auto_select_first_widget(self):
        """Automatically select the first widget, or Linexin Hello on first run."""
        if self.first_widget_loaded:
            return
        config = _load_config()
        is_first_run = not config.get("has_launched_before", False)
        if is_first_run:
            # Mark that the app has been launched
            config["has_launched_before"] = True
            _save_config(config)
            # Try to select Linexin Hello widget
            row = self.widget_list.get_first_child()
            while row:
                if hasattr(row, 'widget_name') and getattr(row, 'widget_name', '') == "Linexin Hello":
                    self.widget_list.select_row(row)
                    self._on_widget_selected(self.widget_list, row)
                    self.first_widget_loaded = True
                    return
                row = row.get_next_sibling()
        # Default: select the first widget
        first_row = self.widget_list.get_first_child()
        if first_row and hasattr(first_row, 'widget_name'):
            self.widget_list.select_row(first_row)
            self._on_widget_selected(self.widget_list, first_row)
            self.first_widget_loaded = True
    def _load_widget_from_file(self, filepath, module_name):
        """Load a widget from a Python file."""
        try:
            spec = importlib.util.spec_from_file_location(module_name, filepath)
            if spec is None:
                return
            loader = spec.loader
            if loader is None:
                return
            module = importlib.util.module_from_spec(spec)
            loader.exec_module(module)
            self._prepare_and_extract_module(module, module_name, filepath)
        except Exception:
            traceback.print_exc()
    def _prepare_module(self, module, module_name, filepath):
        """Set up translation and sudo on a loaded module. Returns (module, filename)."""
        filepath_str: str = str(filepath)
        filename_base: str = os.path.splitext(os.path.basename(filepath_str))[0]
        potential_keys: list[str] = [filename_base]
        if len(filename_base) > 2 and filename_base[1] == '-':
             potential_keys.append(filename_base[2:]) # type: ignore
        underscore_keys: list[str] = [k.replace('-', '_') for k in potential_keys]
        potential_keys.extend(underscore_keys)
        manager = get_localization_manager()
        selected_key = potential_keys[0]
        for key in potential_keys:
            if key in manager.widget_translations:
                selected_key = key
                break
        if selected_key not in manager.widget_translations:
             for key in potential_keys:
                  clean_key: str = key.replace('_widget', '').replace('-widget', '')
                  if clean_key in manager.widget_translations:
                       selected_key = clean_key
                       break
        print(f"DEBUG: Injecting translation for {module_name} using key '{selected_key}'")
        def injected_underscore(message, widget_id=selected_key):
            return _translate_with_patterns_helper(message, widget_id)
        setattr(module, '_', injected_underscore)
        setattr(module, 'sudo_manager', get_sudo_manager())
        filename = os.path.basename(filepath)
        return module, filename
    def _prepare_and_extract_module(self, module, module_name, filepath):
        """Prepare a loaded module and extract widgets from it."""
        try:
            module, filename = self._prepare_module(module, module_name, filepath)
            self._extract_widgets_from_module(module, filename)
        except Exception:
            traceback.print_exc()
    def _extract_widgets_from_module(self, module, filename):
        """Extract widget classes from a loaded module."""
        ctx = GLib.MainContext.default()
        for attribute_name in dir(module):
            attribute = getattr(module, attribute_name)
            if not isinstance(attribute, type):
                continue
            
            # Filter out non-widget classes (like data objects or helpers)
            # This prevents trying to instantiate PackageObject and others
            if not issubclass(attribute, Gtk.Widget):
                continue

            # Flush events before each widget instantiation so the
            # spinner keeps animating and close button stays responsive.
            while ctx.pending():
                ctx.iteration(False)

            try:
                try:
                    widget_instance = attribute(hide_sidebar=self.hide_sidebar, window=self, voice_autostart=self.voice_autostart, conversation_id=self.conversation_id)
                except TypeError:
                    widget_instance = attribute()
                if hasattr(widget_instance, 'widgetname'):
                    self._register_widget(widget_instance, filename)  
            except Exception as e:
                print(f"Failed to instantiate widget in {filename}: {e}")
                import traceback
                traceback.print_exc()
                continue
    def _register_widget(self, widget_instance, filename):
        """Register a widget and add it to the sidebar."""
        widget_name = widget_instance.widgetname
        self.loaded_widgets[widget_name] = widget_instance
        icon_path = getattr(widget_instance, 'widgeticon', None)
        widget_id = getattr(widget_instance, 'widget_id', widget_name.lower().replace(' ', '_'))
        self.widget_metadata[widget_name] = {
            'icon_path': str(icon_path) if icon_path else None,
            'widget_id': str(widget_id),
            'filename': str(filename)
        }
        if widget_name not in self.widget_index:
            self.widget_order.append(widget_name)
            self.widget_index[widget_name] = len(self.widget_order) - 1
        is_hidden = str(filename) in self._hidden_widgets
        translated_name = _(widget_name, widget_id)
        self._add_widget_to_sidebar(widget_name, translated_name, icon_path, is_hidden)
    def _add_widget_to_sidebar(self, widget_name, display_name, icon_path=None, is_hidden=False):
        """Add a widget entry to the sidebar list."""
        row = Adw.ActionRow()
        row.set_title(display_name)
        row.set_activatable(True)
        row.widget_name = widget_name  
        row.display_name = display_name  
        row.is_hidden_widget = is_hidden
        icon = self._load_widget_icon(icon_path)
        row.add_prefix(icon)
        # Hide row if widget is hidden and not in edit mode
        if is_hidden and not self._edit_mode:
            row.set_visible(False)
        self.widget_list.append(row)
        self._sidebar_rows.append(row)
        # Also add a compact icon button
        compact_btn = Gtk.Button()
        compact_btn.add_css_class("flat")
        compact_btn.add_css_class("compact-icon-btn")
        compact_btn.set_halign(Gtk.Align.CENTER)
        compact_btn.set_tooltip_text(display_name)
        compact_btn.widget_name = widget_name
        compact_icon = self._load_widget_icon(icon_path)
        compact_btn.set_child(compact_icon)
        compact_btn.connect("clicked", self._on_compact_icon_clicked)
        if hasattr(self, '_compact_strip'):
            self._compact_strip.append(compact_btn)
        self._compact_icon_buttons.append(compact_btn)
        # Hide compact button too if widget is hidden
        if is_hidden and not self._edit_mode:
            compact_btn.set_visible(False)
    def _load_widget_icon(self, icon_path):
        """Load an icon from a file path or return default icon."""
        if icon_path and not os.path.exists(icon_path) and icon_path.startswith("/usr/share/"):
            relative = icon_path[len("/usr/share/"):]
            source_path = os.path.join(SCRIPT_DIR, "..", "share", relative)
            if os.path.exists(source_path):
                icon_path = os.path.abspath(source_path)
        if not icon_path or not os.path.exists(icon_path):
            image = Gtk.Image.new_from_icon_name("application-x-addon-symbolic")
            image.set_pixel_size(ICON_SIZE)
            return image
        try:
            file_extension = os.path.splitext(icon_path)[1].lower()
            if file_extension == '.svg':
                image = Gtk.Image()
                image.set_from_file(icon_path)
                image.set_pixel_size(ICON_SIZE)
                return image
            else:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_size(
                    icon_path, ICON_SIZE, ICON_SIZE
                )
                texture = Gdk.Texture.new_for_pixbuf(pixbuf)
                image = Gtk.Image.new_from_paintable(texture)
                image.set_pixel_size(ICON_SIZE)
                return image
        except Exception as e:
            print(f"Error loading icon from {icon_path}: {e}")
            image = Gtk.Image.new_from_icon_name("application-x-addon-symbolic")
            image.set_pixel_size(ICON_SIZE)
            return image
    def do_close_request(self):
        """Handle window close request."""
        if getattr(self, 'is_command_locked', False):
            return True 
        if hasattr(self, '_stop_translation_monitoring'):
            self._stop_translation_monitoring()
        for widget in self.loaded_widgets.values():
            if hasattr(widget, '_cleanup_screenshot_tmp'):
                widget._cleanup_screenshot_tmp()
        return False  
    def _on_widget_selected(self, listbox, row):
        """Handle widget selection from the sidebar with debouncing."""
        if getattr(self, 'is_command_locked', False):
            if not hasattr(row, 'widget_name'):
                return
        if self.selection_timeout_id:
            GLib.source_remove(self.selection_timeout_id)
        self.pending_widget_selection = row
        self.selection_timeout_id = GLib.timeout_add(50, self._execute_widget_selection)
    def _execute_widget_selection(self):
        """Execute the actual widget selection after debouncing."""
        row = self.pending_widget_selection
        if not row or not hasattr(row, 'widget_name'):
            self.selection_timeout_id = None
            return False
        widget_name = row.widget_name
        if widget_name not in self.loaded_widgets:
            self.selection_timeout_id = None
            return False
        self._stop_translation_monitoring()
        widget_instance = self.loaded_widgets[widget_name]
        self.active_widget = widget_instance
        self.active_widget_id = self.widget_metadata.get(widget_name, {}).get('widget_id')
        filename = self.widget_metadata.get(widget_name, {}).get('filename', widget_name)
        stack_page_name = self._generate_stack_page_name(filename)
        existing_child = self.widget_stack.get_child_by_name(stack_page_name)
        if existing_child is None:
            self._add_widget_to_stack(widget_instance, widget_name, stack_page_name)
        transition = None
        prev_name = getattr(self, '_visible_widget_name', None)
        if prev_name and prev_name in self.widget_index and widget_name in self.widget_index:
            prev_idx = self.widget_index[prev_name]
            curr_idx = self.widget_index[widget_name]
            if curr_idx > prev_idx:
                transition = Gtk.StackTransitionType.SLIDE_DOWN
            elif curr_idx < prev_idx:
                transition = Gtk.StackTransitionType.SLIDE_UP
        if transition is not None:
            self.widget_stack.set_visible_child_full(stack_page_name, transition)
        else:
            self.widget_stack.set_visible_child_name(stack_page_name)
        self._visible_widget_name = widget_name
        if self.active_widget_id and isinstance(widget_instance, Gtk.Widget):
            self._translate_widget_content(widget_instance, self.active_widget_id)
            self._connect_widget_signals(widget_instance, self.active_widget_id)
        self._start_translation_monitoring()
        display_name = row.display_name if hasattr(row, 'display_name') else widget_name
        self.content_page.set_title(display_name)
        if self._compact_mode:
            self._update_compact_selection(widget_name)
        self.selection_timeout_id = None
        return False
    def _generate_stack_page_name(self, filename_or_widget_name):
        """Generate a consistent stack page name."""
        name = filename_or_widget_name
        if name.endswith('.py'):
            name = name[:-3]
        clean_name = name.lower().replace(' ', '_').replace('-', '_')
        return f"widget_{clean_name}"
    def _add_widget_to_stack(self, widget_instance, widget_name, stack_page_name):
        """Add a widget to the stack with error handling."""
        try:
            if self.widget_stack.get_child_by_name(stack_page_name):
                return  
            if isinstance(widget_instance, Gtk.Widget):
                self.widget_stack.add_named(widget_instance, stack_page_name)
            elif hasattr(widget_instance, 'get_widget'):
                try:
                    gtk_widget = widget_instance.get_widget()
                    self.widget_stack.add_named(gtk_widget, stack_page_name)
                except Exception as e:
                    error_widget = self._create_error_widget(widget_name, str(e))
                    self.widget_stack.add_named(error_widget, stack_page_name)
            else:
                error_widget = self._create_error_widget(widget_name, _("Widget cannot be displayed"))
                self.widget_stack.add_named(error_widget, stack_page_name)
        except Exception as e:
            error_widget = self._create_error_widget(widget_name, str(e))
            try:
                self.widget_stack.add_named(error_widget, stack_page_name)
            except:
                pass  
    def _create_error_widget(self, widget_name, error_message):
        """Create an error widget for display in stack."""
        error_text = _("Error loading") + f" '{widget_name}': {error_message}"
        error_label = Gtk.Label(label=error_text)
        error_label.set_vexpand(True)
        error_label.set_hexpand(True)
        error_label.add_css_class("dim-label")
        return error_label
    def _start_translation_monitoring(self):
        """Start continuous monitoring for dynamic text changes."""
        if self.active_widget and self.active_widget_id:
            self._stop_translation_monitoring()
            self.translation_timer = GLib.timeout_add(100, self._monitor_widget_changes)
    def _stop_translation_monitoring(self):
        """Stop monitoring the current widget."""
        if hasattr(self, 'translation_timer') and self.translation_timer:
            GLib.source_remove(self.translation_timer)
            self.translation_timer = None
    def _connect_widget_signals(self, widget, widget_id):
        """Connect to widget signals for immediate translation updates."""
        try:
            if isinstance(widget, Gtk.Widget):
                widget.connect("notify", lambda w, pspec: self._on_widget_property_changed(w, pspec, widget_id))
            if hasattr(widget, 'get_first_child'):
                child = widget.get_first_child()
                while child:
                    self._connect_widget_signals(child, widget_id)
                    child = child.get_next_sibling()
            elif hasattr(widget, 'get_child'):
                child = widget.get_child()
                if child:
                    self._connect_widget_signals(child, widget_id)
        except Exception:
            pass
    def _on_widget_property_changed(self, widget, param_spec, widget_id):
        """Handle widget property changes for immediate translation."""
        if param_spec.name in ['label', 'text', 'placeholder-text', 'title', 'subtitle', 'description']:
            GLib.idle_add(lambda: self._translate_single_widget(widget, widget_id))    
    def _monitor_widget_changes(self):
        """Monitor and translate any text changes in the active widget."""
        if self.active_widget and self.active_widget_id:
            try:
                if isinstance(self.active_widget, Gtk.Widget):
                    self._translate_widget_content(self.active_widget, self.active_widget_id)
            except Exception:
                pass  
            return True  
        else:
            return False  
    def _translate_widget_content(self, widget, widget_id):
        """Translate all text in the widget using its specific dictionary."""
        self._translate_widget_recursive(widget, widget_id)
    def _translate_widget_recursive(self, widget, widget_id):
        """Recursively translate a widget and all its children."""
        try:
            self._translate_single_widget(widget, widget_id)
            if hasattr(widget, 'get_first_child'):
                child = widget.get_first_child()
                while child:
                    self._translate_widget_recursive(child, widget_id)
                    child = child.get_next_sibling()
            elif hasattr(widget, 'get_child'):
                child = widget.get_child()
                if child:
                    self._translate_widget_recursive(child, widget_id)
        except Exception:
            pass  
    def _translate_markup_content(self, markup_text, widget_id):
        """Enhanced markup translation that handles both dynamic patterns and multiline descriptions."""
        markup_text = _translate_with_patterns_helper(markup_text, widget_id)
        def replace_text(match):
            text_content = match.group(1)
            if text_content.strip():
                translated = _(text_content.strip(), widget_id)
                if translated != text_content.strip():
                    leading_space = text_content[:len(text_content) - len(text_content.lstrip())]
                    trailing_space = text_content[len(text_content.rstrip()):]
                    return ">" + leading_space + translated + trailing_space + "<"
            return ">" + text_content + "<"
        return re.sub(r'>([^<]+)<', replace_text, markup_text)
    def _translate_single_widget(self, widget, widget_id):
        """Translate text in a single widget."""
        try:
            if isinstance(widget, Gtk.Label):
                if widget.get_use_markup():
                    markup = widget.get_label()  
                    if markup:
                        translated_markup = self._translate_markup_content(markup, widget_id)
                        if translated_markup != markup:
                            widget.set_markup(translated_markup)
                else:
                    text = widget.get_text()
                    if text:
                        translated = _translate_with_patterns_helper(text, widget_id)
                        if translated != text:
                            widget.set_text(translated)
            elif isinstance(widget, Gtk.Button):
                label = widget.get_label()
                if label:
                    translated = _translate_with_patterns_helper(label, widget_id)
                    if translated != label:
                        widget.set_label(translated)
            elif isinstance(widget, (Gtk.Entry, Gtk.SearchEntry, Gtk.PasswordEntry)):
                placeholder = widget.get_placeholder_text()
                if placeholder:
                    translated = _translate_with_patterns_helper(placeholder, widget_id)
                    if translated != placeholder:
                        widget.set_placeholder_text(translated)
            elif isinstance(widget, Adw.ActionRow):
                title = widget.get_title()
                if title:
                    translated = _translate_with_patterns_helper(title, widget_id)
                    if translated != title:
                        widget.set_title(translated)
                subtitle = widget.get_subtitle()
                if subtitle:
                    translated = _translate_with_patterns_helper(subtitle, widget_id)
                    if translated != subtitle:
                        widget.set_subtitle(translated)
                if isinstance(widget, Adw.ComboRow):
                    combo_model = widget.get_model()
                    if isinstance(combo_model, Gtk.StringList):
                        for i in range(combo_model.get_n_items()):
                            s = combo_model.get_string(i)
                            if s:
                                t = _translate_with_patterns_helper(s, widget_id)
                                if t != s:
                                    combo_model.splice(i, 1, [t])
            elif isinstance(widget, Adw.PreferencesRow):
                title = widget.get_title()
                if title:
                    translated = _translate_with_patterns_helper(title, widget_id)
                    if translated != title:
                        widget.set_title(translated)
            elif isinstance(widget, Adw.PreferencesGroup):
                title = widget.get_title()
                if title:
                    translated = _translate_with_patterns_helper(title, widget_id)
                    if translated != title:
                        widget.set_title(translated)
                desc = widget.get_description()
                if desc:
                    translated = _translate_with_patterns_helper(desc, widget_id)
                    if translated != desc:
                        widget.set_description(translated)
            elif isinstance(widget, Adw.PreferencesPage):
                title = widget.get_title()
                if title:
                    translated = _translate_with_patterns_helper(title, widget_id)
                    if translated != title:
                        widget.set_title(translated)
            elif isinstance(widget, Adw.StatusPage):
                title = widget.get_title()
                if title:
                    translated = _translate_with_patterns_helper(title, widget_id)
                    if translated != title:
                        widget.set_title(translated)
                desc = widget.get_description()
                if desc:
                    translated = _translate_with_patterns_helper(desc, widget_id)
                    if translated != desc:
                        widget.set_description(translated)
            elif isinstance(widget, (Gtk.Window, Adw.ApplicationWindow)):
                title = widget.get_title()
                if title:
                    translated = _(title, widget_id)
                    if translated != title:
                        widget.set_title(translated)
            if hasattr(widget, 'get_visible') and widget.get_visible():
                pass
        except Exception:
            pass  
    def _apply_saved_compact(self) -> bool:
        """Apply saved compact mode on startup (no animation)."""
        self._set_compact_mode(True, animated=False)
        return False

    def _on_compact_toggle_clicked(self, button: Any) -> None:
        """Handle manual compact mode toggle button click."""
        new_compact: bool = not self._compact_mode
        self._set_compact_mode(new_compact, animated=True)
        config: Dict[str, Any] = _load_config()
        config["compact_mode"] = new_compact
        _save_config(config)

    def _on_edit_toggle_clicked(self, button: Any) -> None:
        """Toggle edit mode for rearranging and hiding widgets."""
        if self._edit_mode:
            self._exit_edit_mode()
        else:
            self._enter_edit_mode()

    def _enter_edit_mode(self) -> None:
        """Enter edit mode with staggered iOS/Material-style animations."""
        # If in compact mode, switch to normal first
        if self._compact_mode:
            self._set_compact_mode(False, animated=True)
        self._edit_mode = True
        self._drag_controllers: Dict[str, list] = {}
        self._edit_row_anims: list = []
        self._compact_toggle_btn.set_sensitive(False)

        # Animate edit button: spin + morph to "Done" style
        self._edit_toggle_btn.add_css_class("edit-btn-spinning")
        GLib.timeout_add(300, self._finish_edit_btn_enter)

        # Prepare rows: start invisible/scaled-down, then stagger them in
        for i, row in enumerate(self._sidebar_rows):
            row.set_visible(True)
            widget_name = getattr(row, 'widget_name', '')
            is_hidden = getattr(row, 'is_hidden_widget', False)
            if is_hidden:
                row.add_css_class("edit-hidden-row")
            # Start in pre-animation state
            row.add_css_class("edit-row-enter-prep")
            self._add_edit_controls_to_row(row, widget_name, is_hidden)
            self._attach_dnd_controllers(row)
            # Stagger the reveal: each row animates 40ms after the previous
            GLib.timeout_add(60 + i * 40, self._animate_row_enter, row)

    def _finish_edit_btn_enter(self) -> bool:
        """Finish the edit button enter transition."""
        self._edit_toggle_btn.remove_css_class("edit-btn-spinning")
        self._edit_toggle_btn.set_icon_name("object-select-symbolic")
        self._edit_toggle_btn.set_tooltip_text(_("Done"))
        self._edit_toggle_btn.add_css_class("suggested-action")
        self._edit_toggle_btn.add_css_class("edit-btn-active")
        return False

    def _animate_row_enter(self, row) -> bool:
        """Trigger the enter animation for a single row."""
        row.remove_css_class("edit-row-enter-prep")
        row.add_css_class("edit-row-enter")
        # Clean up the animation class after it completes
        GLib.timeout_add(400, self._cleanup_row_enter_class, row)
        return False

    def _cleanup_row_enter_class(self, row) -> bool:
        """Remove the enter animation class after animation completes."""
        row.remove_css_class("edit-row-enter")
        return False

    def _exit_edit_mode(self) -> None:
        """Exit edit mode with smooth Material-style animations."""
        self._edit_mode = False
        self._compact_toggle_btn.set_sensitive(True)

        # Animate edit button back
        self._edit_toggle_btn.remove_css_class("edit-btn-active")
        self._edit_toggle_btn.remove_css_class("suggested-action")
        self._edit_toggle_btn.add_css_class("edit-btn-spinning")
        GLib.timeout_add(300, self._finish_edit_btn_exit)

        # Stagger rows out, then clean up after all animations finish
        total_rows = len(self._sidebar_rows)
        for i, row in enumerate(self._sidebar_rows):
            row.remove_css_class("edit-drop-above")
            row.remove_css_class("edit-drop-below")
            GLib.timeout_add(i * 30, self._animate_row_exit, row)

        # Final cleanup after all row animations + buffer
        cleanup_delay = total_rows * 30 + 350
        GLib.timeout_add(cleanup_delay, self._finish_exit_edit_mode)

    def _finish_edit_btn_exit(self) -> bool:
        """Finish the edit button exit transition."""
        self._edit_toggle_btn.remove_css_class("edit-btn-spinning")
        self._edit_toggle_btn.set_icon_name("document-edit-symbolic")
        self._edit_toggle_btn.set_tooltip_text(_("Edit widgets"))
        return False

    def _animate_row_exit(self, row) -> bool:
        """Trigger the exit animation for a single row."""
        row.add_css_class("edit-row-exit")
        return False

    def _finish_exit_edit_mode(self) -> bool:
        """Clean up after all exit animations have completed."""
        for row in self._sidebar_rows:
            widget_name = getattr(row, 'widget_name', '')
            row.remove_css_class("edit-hidden-row")
            row.remove_css_class("edit-row-exit")
            row.remove_css_class("edit-row-enter")
            row.remove_css_class("edit-row-enter-prep")
            self._remove_edit_controls_from_row(row)
            self._detach_dnd_controllers(row)
            is_hidden = getattr(row, 'is_hidden_widget', False)
            row.set_visible(not is_hidden)
            # Also update compact icon visibility
            for btn in self._compact_icon_buttons:
                if getattr(btn, 'widget_name', '') == widget_name:
                    btn.set_visible(not is_hidden)
                    break
        # If we hid the currently selected widget, select the first visible one
        selected = self.widget_list.get_selected_row()
        if selected and getattr(selected, 'is_hidden_widget', False):
            self._auto_select_first_visible_widget()
        self._save_widget_config()
        return False

    def _add_edit_controls_to_row(self, row, widget_name: str, is_hidden: bool) -> None:
        """Add move up/down buttons and visibility toggle to a sidebar row."""
        suffix_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        suffix_box.add_css_class("edit-controls-box")

        # Visibility toggle button
        vis_btn = Gtk.Button()
        vis_btn.add_css_class("flat")
        vis_btn.add_css_class("edit-vis-btn")
        if is_hidden:
            vis_btn.set_icon_name("view-reveal-symbolic")
            vis_btn.set_tooltip_text(_("Show widget"))
        else:
            vis_btn.set_icon_name("view-conceal-symbolic")
            vis_btn.set_tooltip_text(_("Hide widget"))
        vis_btn.connect("clicked", self._on_toggle_widget_visibility, row)
        suffix_box.append(vis_btn)

        # Move up button
        up_btn = Gtk.Button()
        up_btn.add_css_class("flat")
        up_btn.add_css_class("edit-move-btn")
        up_btn.set_icon_name("go-up-symbolic")
        up_btn.set_tooltip_text(_("Move up"))
        up_btn.connect("clicked", self._on_move_widget_up, row)
        suffix_box.append(up_btn)

        # Move down button
        down_btn = Gtk.Button()
        down_btn.add_css_class("flat")
        down_btn.add_css_class("edit-move-btn")
        down_btn.set_icon_name("go-down-symbolic")
        down_btn.set_tooltip_text(_("Move down"))
        down_btn.connect("clicked", self._on_move_widget_down, row)
        suffix_box.append(down_btn)

        row.add_suffix(suffix_box)
        self._edit_suffix_widgets[widget_name] = [suffix_box]

    def _remove_edit_controls_from_row(self, row) -> None:
        """Remove edit controls from a sidebar row."""
        widget_name = getattr(row, 'widget_name', '')
        if widget_name in self._edit_suffix_widgets:
            for widget in self._edit_suffix_widgets[widget_name]:
                row.remove(widget)
            del self._edit_suffix_widgets[widget_name]

    def _on_toggle_widget_visibility(self, button: Any, row: Any) -> None:
        """Toggle the hidden state of a widget in edit mode."""
        widget_name = getattr(row, 'widget_name', '')
        filename = self.widget_metadata.get(widget_name, {}).get('filename', '')
        is_hidden = getattr(row, 'is_hidden_widget', False)
        new_hidden = not is_hidden
        row.is_hidden_widget = new_hidden
        if new_hidden:
            self._hidden_widgets.add(filename)
            row.add_css_class("edit-hidden-row")
            button.set_icon_name("view-reveal-symbolic")
            button.set_tooltip_text(_("Show widget"))
        else:
            self._hidden_widgets.discard(filename)
            row.remove_css_class("edit-hidden-row")
            button.set_icon_name("view-conceal-symbolic")
            button.set_tooltip_text(_("Hide widget"))

    def _on_move_widget_up(self, button: Any, row: Any) -> None:
        """Move a widget up in the sidebar order."""
        widget_name = getattr(row, 'widget_name', '')
        idx = self._sidebar_rows.index(row) if row in self._sidebar_rows else -1
        if idx <= 0:
            return
        self._swap_widgets(idx, idx - 1)

    def _on_move_widget_down(self, button: Any, row: Any) -> None:
        """Move a widget down in the sidebar order."""
        widget_name = getattr(row, 'widget_name', '')
        idx = self._sidebar_rows.index(row) if row in self._sidebar_rows else -1
        if idx < 0 or idx >= len(self._sidebar_rows) - 1:
            return
        self._swap_widgets(idx, idx + 1)

    def _swap_widgets(self, idx_a: int, idx_b: int) -> None:
        """Swap two widgets in sidebar, compact strip, and internal order."""
        # Swap in _sidebar_rows
        self._sidebar_rows[idx_a], self._sidebar_rows[idx_b] = \
            self._sidebar_rows[idx_b], self._sidebar_rows[idx_a]
        # Swap in widget_order
        self.widget_order[idx_a], self.widget_order[idx_b] = \
            self.widget_order[idx_b], self.widget_order[idx_a]
        # Update widget_index
        for i, name in enumerate(self.widget_order):
            self.widget_index[name] = i
        # Swap in compact icon buttons
        if idx_a < len(self._compact_icon_buttons) and idx_b < len(self._compact_icon_buttons):
            self._compact_icon_buttons[idx_a], self._compact_icon_buttons[idx_b] = \
                self._compact_icon_buttons[idx_b], self._compact_icon_buttons[idx_a]
        # Reorder the actual GTK ListBox rows
        self._rebuild_listbox_order()
        # Reorder compact strip
        self._rebuild_compact_strip_order()

    def _move_widget_to(self, src_idx: int, dst_idx: int) -> None:
        """Move a widget from src_idx to dst_idx, shifting others accordingly."""
        if src_idx == dst_idx or src_idx < 0 or dst_idx < 0:
            return
        if src_idx >= len(self._sidebar_rows) or dst_idx >= len(self._sidebar_rows):
            return
        # Move in _sidebar_rows
        row = self._sidebar_rows.pop(src_idx)
        self._sidebar_rows.insert(dst_idx, row)
        # Move in widget_order
        name = self.widget_order.pop(src_idx)
        self.widget_order.insert(dst_idx, name)
        # Rebuild widget_index
        for i, n in enumerate(self.widget_order):
            self.widget_index[n] = i
        # Move in compact icon buttons
        if src_idx < len(self._compact_icon_buttons) and dst_idx < len(self._compact_icon_buttons):
            btn = self._compact_icon_buttons.pop(src_idx)
            self._compact_icon_buttons.insert(dst_idx, btn)
        self._rebuild_listbox_order()
        self._rebuild_compact_strip_order()

    def _attach_dnd_controllers(self, row) -> None:
        """Attach drag source and drop target controllers to a row for reordering."""
        widget_name = getattr(row, 'widget_name', '')
        # Drag source
        drag_source = Gtk.DragSource()
        drag_source.set_actions(Gdk.DragAction.MOVE)
        drag_source.connect("prepare", self._on_drag_prepare, row)
        drag_source.connect("drag-begin", self._on_drag_begin, row)
        drag_source.connect("drag-end", self._on_drag_end, row)
        row.add_controller(drag_source)
        # Drop target
        drop_target = Gtk.DropTarget.new(GObject.TYPE_INT, Gdk.DragAction.MOVE)
        drop_target.connect("motion", self._on_drop_motion, row)
        drop_target.connect("leave", self._on_drop_leave, row)
        drop_target.connect("drop", self._on_drop_drop, row)
        row.add_controller(drop_target)
        self._drag_controllers[widget_name] = [drag_source, drop_target]

    def _detach_dnd_controllers(self, row) -> None:
        """Remove drag source and drop target controllers from a row."""
        widget_name = getattr(row, 'widget_name', '')
        if widget_name in self._drag_controllers:
            for ctrl in self._drag_controllers[widget_name]:
                row.remove_controller(ctrl)
            del self._drag_controllers[widget_name]

    def _on_drag_prepare(self, source, x, y, row):
        """Prepare drag data: provide the source row index."""
        idx = self._sidebar_rows.index(row) if row in self._sidebar_rows else -1
        if idx < 0:
            return None
        content = Gdk.ContentProvider.new_for_value(GObject.Value(GObject.TYPE_INT, idx))
        return content

    def _on_drag_begin(self, source, drag, row):
        """Visual feedback when drag starts."""
        row.add_css_class("edit-dragging")
        # Use a label as the drag icon
        display_name = getattr(row, 'display_name', '?')
        label = Gtk.Label(label=display_name)
        label.add_css_class("heading")
        label.set_margin_start(12)
        label.set_margin_end(12)
        label.set_margin_top(6)
        label.set_margin_bottom(6)
        Gtk.DragIcon.get_for_drag(drag).set_child(label)
        drag.set_hotspot(row.get_width() // 2, row.get_height() // 2)

    def _on_drag_end(self, source, drag, delete, row):
        """Clean up after drag ends."""
        row.remove_css_class("edit-dragging")

    def _on_drop_motion(self, target, x, y, row):
        """Show drop indicator based on cursor position within the row."""
        row_h = row.get_height()
        if y < row_h / 2:
            row.add_css_class("edit-drop-above")
            row.remove_css_class("edit-drop-below")
        else:
            row.add_css_class("edit-drop-below")
            row.remove_css_class("edit-drop-above")
        return Gdk.DragAction.MOVE

    def _on_drop_leave(self, target, row):
        """Remove drop indicators when cursor leaves."""
        row.remove_css_class("edit-drop-above")
        row.remove_css_class("edit-drop-below")

    def _on_drop_drop(self, target, value, x, y, row):
        """Handle the actual drop: reorder the widget."""
        src_idx = value
        dst_idx = self._sidebar_rows.index(row) if row in self._sidebar_rows else -1
        if src_idx < 0 or dst_idx < 0 or src_idx == dst_idx:
            row.remove_css_class("edit-drop-above")
            row.remove_css_class("edit-drop-below")
            return False
        # Determine if dropping above or below the target
        row_h = row.get_height()
        if y >= row_h / 2 and dst_idx >= src_idx:
            dst_idx = min(dst_idx, len(self._sidebar_rows) - 1)
        elif y >= row_h / 2 and dst_idx < src_idx:
            dst_idx = min(dst_idx + 1, len(self._sidebar_rows) - 1)
        elif y < row_h / 2 and dst_idx > src_idx:
            dst_idx = max(dst_idx - 1, 0)
        row.remove_css_class("edit-drop-above")
        row.remove_css_class("edit-drop-below")
        self._move_widget_to(src_idx, dst_idx)
        return True

    def _rebuild_listbox_order(self) -> None:
        """Rebuild the ListBox to match _sidebar_rows order."""
        # Remove all rows from listbox
        for row in self._sidebar_rows:
            self.widget_list.remove(row)
        # Re-add in correct order
        for row in self._sidebar_rows:
            self.widget_list.append(row)

    def _rebuild_compact_strip_order(self) -> None:
        """Rebuild the compact strip to match _compact_icon_buttons order."""
        if not hasattr(self, '_compact_strip'):
            return
        for btn in self._compact_icon_buttons:
            self._compact_strip.remove(btn)
        for btn in self._compact_icon_buttons:
            self._compact_strip.append(btn)

    def _auto_select_first_visible_widget(self) -> None:
        """Select the first visible widget in the sidebar."""
        for row in self._sidebar_rows:
            if row.get_visible() and not getattr(row, 'is_hidden_widget', False):
                self.widget_list.select_row(row)
                self._on_widget_selected(self.widget_list, row)
                return

    def _save_widget_config(self) -> None:
        """Save widget order and hidden widgets to config."""
        config = _load_config()
        # Build order list from filenames
        order_filenames = []
        for widget_name in self.widget_order:
            meta = self.widget_metadata.get(widget_name, {})
            filename = meta.get('filename', '')
            if filename:
                order_filenames.append(filename)
        config["widget_order"] = order_filenames
        config["hidden_widgets"] = list(self._hidden_widgets)
        _save_config(config)

    def _on_compact_icon_clicked(self, button: Any) -> None:
        """Handle click on a compact mode icon to select the corresponding widget."""
        widget_name: str = str(getattr(button, 'widget_name', ''))
        # Find the corresponding row in the normal list and activate it
        row = self.widget_list.get_first_child()
        while row:
            if hasattr(row, 'widget_name') and getattr(row, 'widget_name', '') == widget_name:
                self.widget_list.select_row(row)
                self._on_widget_selected(self.widget_list, row)
                break
            row = row.get_next_sibling()
        # Update compact icon selection styling
        self._update_compact_selection(widget_name)

    def _update_compact_selection(self, selected_name: str) -> None:
        """Update visual selection state of compact icon buttons."""
        for btn in self._compact_icon_buttons:
            if getattr(btn, 'widget_name', '') == selected_name:
                btn.add_css_class("compact-icon-selected")
            else:
                btn.remove_css_class("compact-icon-selected")

    def _set_compact_mode(self, compact: bool, animated: bool=True) -> None:
        """Switch between compact and normal sidebar modes."""
        if self._compact_mode == compact:
            return
        self._compact_mode = compact
        if compact:
            self._transition_to_compact(animated)
        else:
            self._transition_to_normal(animated)

    def _apply_sidebar_width(self, w: int) -> None:
        """Set the split view sidebar to exactly w pixels."""
        self.split_view.set_min_sidebar_width(w)
        self.split_view.set_max_sidebar_width(w)

    def _animate_toggle_button(self, target_deg: float, animated: bool) -> None:
        """Animate the compact toggle button rotation to target_deg."""
        if self._btn_rotate_anim is not None:
            if hasattr(self._btn_rotate_anim, 'skip'):
                getattr(self._btn_rotate_anim, 'skip')()
            self._btn_rotate_anim = None
        if not animated:
            self._btn_rotation_deg = target_deg
            self._apply_btn_rotation(target_deg)
            return
        start_deg = self._btn_rotation_deg
        def _on_tick(v: float) -> None:
            self._btn_rotation_deg = v
            self._apply_btn_rotation(v)
        target: Any = Adw.CallbackAnimationTarget.new(_on_tick) # type: ignore
        anim = Adw.TimedAnimation.new(
            self._compact_toggle_btn,
            float(start_deg),
            float(target_deg),
            COMPACT_ANIM_DURATION,
            target
        )
        anim.set_easing(Adw.Easing.EASE_IN_OUT_CUBIC)
        self._btn_rotate_anim = anim
        anim.play()

    def _apply_btn_rotation(self, deg: float) -> None:
        """Apply rotation transform to the toggle button via CSS."""
        css = f".compact-toggle-btn {{ transition: none; transform: rotate({deg}deg); }}"
        self._btn_css_provider.load_from_data(css.encode())

    def _transition_to_compact(self, animated: bool) -> None:
        """Animate transition to compact mode."""
        selected = self.widget_list.get_selected_row()
        if selected and hasattr(selected, 'widget_name'):
            selected_name: str = str(getattr(selected, 'widget_name', ''))
            self._update_compact_selection(selected_name)
        self._animate_toggle_button(0.0, animated)

        def _swap_to_compact() -> None:
            if hasattr(self, '_sidebar_header_title'):
                self._sidebar_header_title.set_visible(False)
            self._widget_list_container.set_visible(False)
            self._compact_scroll.set_visible(True)
            self._compact_strip.set_visible(True)

        if animated:
            if self._sidebar_anim is not None:
                if hasattr(self._sidebar_anim, 'skip'):
                    getattr(self._sidebar_anim, 'skip')()
                self._sidebar_anim = None
            # Swap content at the midpoint of the width animation
            mid = (SIDEBAR_WIDTH + SIDEBAR_COMPACT_WIDTH) / 2.0
            swapped: list[bool] = [False]
            def _on_tick(v: float) -> None:
                self._apply_sidebar_width(int(v))
                if not swapped[0] and v <= mid:
                    swapped[0] = True
                    _swap_to_compact()
            target_anim: Any = Adw.CallbackAnimationTarget.new(_on_tick) # type: ignore
            anim = Adw.TimedAnimation.new(
                self.split_view,
                float(SIDEBAR_WIDTH),
                float(SIDEBAR_COMPACT_WIDTH),
                COMPACT_ANIM_DURATION,
                target_anim
            )
            anim.set_easing(Adw.Easing.EASE_IN_OUT_CUBIC)
            self._sidebar_anim = anim
            anim.play()
        else:
            _swap_to_compact()
            self._apply_sidebar_width(SIDEBAR_COMPACT_WIDTH)

    def _transition_to_normal(self, animated: bool) -> None:
        """Animate transition to normal mode."""
        self._animate_toggle_button(180.0, animated)

        def _swap_to_normal() -> None:
            if hasattr(self, '_sidebar_header_title'):
                self._sidebar_header_title.set_visible(True)
            self._widget_list_container.set_visible(True)
            self._compact_scroll.set_visible(False)
            self._compact_strip.set_visible(False)

        if animated:
            if self._sidebar_anim is not None:
                if hasattr(self._sidebar_anim, 'skip'):
                    getattr(self._sidebar_anim, 'skip')()
                self._sidebar_anim = None
            # Swap content at the midpoint of the width animation
            mid = (SIDEBAR_WIDTH + SIDEBAR_COMPACT_WIDTH) / 2.0
            swapped: list[bool] = [False]
            def _on_tick(v: float) -> None:
                self._apply_sidebar_width(int(v))
                if not swapped[0] and v >= mid:
                    swapped[0] = True
                    _swap_to_normal()
            def _on_done(anim_done: Any) -> None:
                self._sidebar_anim = None
            target_anim: Any = Adw.CallbackAnimationTarget.new(_on_tick) # type: ignore
            anim = Adw.TimedAnimation.new(
                self.split_view,
                float(SIDEBAR_COMPACT_WIDTH),
                float(SIDEBAR_WIDTH),
                COMPACT_ANIM_DURATION,
                target_anim
            )
            anim.set_easing(Adw.Easing.EASE_IN_OUT_CUBIC)
            anim.connect("done", _on_done)
            self._sidebar_anim = anim
            anim.play()
        else:
            self._apply_sidebar_width(SIDEBAR_WIDTH)
            _swap_to_normal()

    def _on_button_layout_changed(self, settings, key):
        """Handle changes to window button layout from GNOME settings."""
        self.current_button_layout = settings.get_string("button-layout")
        self._rebuild_headers()
    def _rebuild_headers(self):
        """Rebuild headers when button layout changes."""
        selected_row = self.widget_list.get_selected_row()
        selected_widget = (
            selected_row.widget_name 
            if selected_row and hasattr(selected_row, 'widget_name') 
            else None
        )
        current_content = self.content_display.get_child()
        if self.widget_list.get_parent():
            self.widget_list.get_parent().set_child(None)
        # Detach compact icon buttons from old strip
        for btn in self._compact_icon_buttons:
            parent = btn.get_parent()
            if parent:
                parent.remove(btn)
        if self.content_display.get_parent():
            self.content_display.get_parent().remove(self.content_display)
        was_compact = self._compact_mode
        self._build_sidebar()
        self._build_content_area()
        # Re-add compact icon buttons to new strip
        for btn in self._compact_icon_buttons:
            self._compact_strip.append(btn)
        # Restore compact state
        if was_compact:
            self._compact_mode = False
            self._set_compact_mode(True, animated=False)
        self.split_view.set_sidebar(self.sidebar_page)
        self.split_view.set_content(self.content_page)
        if current_content:
            self.content_display.set_child(current_content)
        if selected_widget:
            self._restore_selection(selected_widget)
    def _restore_selection(self, widget_name):
        """Restore widget selection after UI rebuild."""
        for row in self.widget_list:
            if hasattr(row, 'widget_name') and getattr(row, 'widget_name') == widget_name:
                self.widget_list.select_row(row)
                break
    def _parse_button_layout(self):
        """Parse the button layout string to determine left/right buttons."""
        if ":" in self.current_button_layout:
            left, right = self.current_button_layout.split(":")
            return left, right
        else:
            return self.current_button_layout, ""
    def _show_placeholder_message(self):
        """Show placeholder message in content area."""
        placeholder = Gtk.Label(label=_("Select a widget from the sidebar"))
        placeholder.set_vexpand(True)
        placeholder.set_hexpand(True)
        self.content_display.set_child(placeholder)
    def _show_error_in_list(self, title, subtitle):
        """Show error message in the widget list."""
        row = Adw.ActionRow()
        row.set_title(title)
        row.set_subtitle(subtitle)
        self.widget_list.append(row)
    def _apply_styling(self):
        """Apply custom CSS styling to the application."""
        css = """
            /* Flat header bars with transparent background */
            headerbar.flat {
                min-height: 0;
                padding-top: 3px;
                padding-bottom: 3px;
                background: transparent;
                border: none;
                box-shadow: none;
            }
            /* Invisible separators */
            .hidden-separator {
                opacity: 0;
                min-height: 1px;
            }
            /* Dim label for errors */
            .dim-label {
                opacity: 0.6;
            }
            /* Add spacing between sidebar widgets */
            .navigation-sidebar row {
                margin-bottom: 6px;
            }            
            .buttons_all {
                font-size: 14px;
                min-width: 200px;
                min-height: 40px;
            }
            /* Command execution lock visual feedback */
            widget:insensitive {
                opacity: 0.3;
            }
            .command-locked {
                background: alpha(@warning_color, 0.1);
            }
            /* Compact mode icon button */
            .compact-icon-btn {
                min-width: 40px;
                min-height: 40px;
                padding: 6px;
                border-radius: 10px;
                margin: 2px 2px;
            }
            .compact-icon-btn:hover {
                background: alpha(@accent_color, 0.15);
            }
            .compact-icon-selected {
                background: alpha(@accent_color, 0.25);
            }
            .compact-icon-selected:hover {
                background: alpha(@accent_color, 0.35);
            }
            /* Compact toggle button */
            .compact-toggle-btn {
                min-width: 32px;
                min-height: 32px;
                border-radius: 50%;
            }
            .compact-toggle-btn image {
                transition: none;
            }
            /* Edit mode toggle button */
            .edit-toggle-btn {
                min-width: 32px;
                min-height: 32px;
                border-radius: 50%;
                transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
                            background-color 250ms ease;
            }
            .edit-btn-spinning {
                transform: rotate(180deg) scale(0.8);
            }
            .edit-btn-active {
                transform: scale(1.05);
            }
            /* Edit mode: hidden widget row dimmed */
            .edit-hidden-row {
                opacity: 0.4;
                transition: opacity 250ms ease;
            }
            /* Edit mode row enter animations */
            .edit-row-enter-prep {
                opacity: 0;
                transform: translateX(-12px) scale(0.95);
            }
            .edit-row-enter {
                opacity: 1;
                transform: translateX(0px) scale(1);
                transition: opacity 300ms cubic-bezier(0.0, 0.0, 0.2, 1),
                            transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
            }
            /* Edit mode row exit animations */
            .edit-row-exit {
                opacity: 0.6;
                transform: scale(0.97);
                transition: opacity 250ms ease-out,
                            transform 250ms ease-out;
            }
            /* Edit controls slide-in */
            .edit-controls-box {
                transition: opacity 300ms cubic-bezier(0.0, 0.0, 0.2, 1),
                            transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
            }
            /* Edit mode control buttons */
            .edit-move-btn, .edit-vis-btn {
                min-width: 28px;
                min-height: 28px;
                padding: 2px;
            }
            /* Drag and drop indicators */
            .edit-dragging {
                opacity: 0.4;
            }
            .edit-drop-above {
                border-top: 2px solid @accent_color;
            }
            .edit-drop-below {
                border-bottom: 2px solid @accent_color;
            }
        """
        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_display(
            self.get_display(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
class WidgetLoaderApp(Adw.Application):
    """Main application class."""
    def __init__(self, **kwargs: Any):
        flags = Gio.ApplicationFlags.NON_UNIQUE if os.environ.get("LINEXIN_NEW_INSTANCE") else Gio.ApplicationFlags.FLAGS_NONE
        super().__init__(application_id=APP_ID, flags=flags) # type: ignore
        self.connect('activate', self.on_activate)
        self.hide_sidebar: bool = False
        self.target_widget: Optional[str] = None
        self.voice_autostart: bool = False
        self.compact_mode: bool = False
        self.conversation_id: Optional[str] = None
        self.window: Optional[WidgetLoaderWindow] = None
        self._parse_arguments()
    def _parse_arguments(self):
        """Parse command line arguments manually."""
        import sys
        print(f"Command line arguments: {sys.argv}")
        new_argv: list[str] = []
        
        args_iter = iter(sys.argv)
        
        try:
            first_arg: str = next(args_iter)
            new_argv.append(str(first_arg))
        except StopIteration:
            pass
            
        while True:
            try:
                arg: str = next(args_iter)
            except StopIteration:
                break
                
            if arg == '--widget' or arg == '-w':
                try:
                    target_arg: str = next(args_iter)
                    self.target_widget = str(target_arg)
                    self.hide_sidebar = True
                    print(f"Found widget argument: {self.target_widget}")
                except StopIteration:
                    print("Error: --widget requires a widget name")
                    sys.exit(1)
            elif arg == '--voice':
                self.voice_autostart = True
            elif arg == '--compact':
                self.compact_mode = True
            elif arg == '--conversation':
                try:
                    conv_arg: str = next(args_iter)
                    self.conversation_id = str(conv_arg)
                except StopIteration:
                    print("Error: --conversation requires a conversation id")
                    sys.exit(1)
            elif arg == '--version' or arg == '-v':
                print(f"Linexin Tools v{APP_VERSION}")
                sys.exit(0)
            else:
                new_argv.append(str(arg))
                
        sys.argv.clear()
        sys.argv.extend(new_argv)
        print(f"Cleaned arguments for GTK: {sys.argv}")
        print(f"Final settings: hide_sidebar={self.hide_sidebar}, target_widget={self.target_widget}, voice_autostart={self.voice_autostart}, compact_mode={self.compact_mode}, conversation_id={self.conversation_id}")

    def on_activate(self, app: Adw.Application) -> None:
        """Handle application activation."""
        # Compact voice mode — launch the small floating pill bar instead
        if self.compact_mode and self.target_widget:
            self._launch_compact_voice(app)
            return

        window_instance = WidgetLoaderWindow(
            application=app,
            hide_sidebar=self.hide_sidebar,
            target_widget=self.target_widget,
            voice_autostart=self.voice_autostart,
            conversation_id=self.conversation_id,
        )
        self.window = window_instance
        window_instance.present()

        def _sigusr1_handler(signum, frame):
            """Reactivate voice input on the active widget when SIGUSR1 is received."""
            GLib.idle_add(self._reactivate_voice)

        signal.signal(signal.SIGUSR1, _sigusr1_handler)

    def _reactivate_voice(self):
        """Reactivate voice input on the active widget."""
        win = self.window
        if win and hasattr(win, 'active_widget'):
            widget = win.active_widget
            if widget and hasattr(widget, 'stt_toggle'):
                toggle = widget.stt_toggle
                # Deactivate first if already active so re-toggling restarts STT
                if toggle.get_active():
                    toggle.set_active(False)
                toggle.set_active(True)
        return False  # Don't repeat the GLib idle callback

    def _launch_compact_voice(self, app: Adw.Application) -> None:
        """Launch the compact floating voice bar from the target widget module."""
        widget_dir = str(Path(__file__).resolve().parent.parent / "share" / "linexin" / "widgets")
        target = self.target_widget or ""
        filepath = os.path.join(widget_dir, target + ".py")
        if not os.path.isfile(filepath):
            print(f"Error: widget file not found: {filepath}")
            return
        spec = importlib.util.spec_from_file_location(target, filepath)
        if spec is None or spec.loader is None:
            print(f"Error: cannot load widget module: {filepath}")
            return
        module = importlib.util.module_from_spec(spec)
        # Inject translation + sudo
        manager = get_localization_manager()
        potential_keys = [target, target.replace('-', '_')]
        if len(target) > 2 and target[1] == '-':
            potential_keys.append(target[2:])
        potential_keys.extend([k.replace('_widget', '').replace('-widget', '') for k in list(potential_keys)])
        selected_key = potential_keys[0]
        for key in potential_keys:
            if key in manager.widget_translations:
                selected_key = key
                break
        def injected_underscore(message, widget_id=selected_key):
            return _translate_with_patterns_helper(message, widget_id)
        setattr(module, '_', injected_underscore)
        setattr(module, 'sudo_manager', get_sudo_manager())
        spec.loader.exec_module(module)
        compact_cls = getattr(module, 'CompactVoiceWindow', None)
        if compact_cls is None:
            print("Error: CompactVoiceWindow class not found in widget module")
            return
        win = compact_cls(
            application=app,
            voice_autostart=self.voice_autostart,
        )
        self.window = win
        win.present()

        def _sigusr1_handler(signum, frame):
            GLib.idle_add(self._reactivate_voice_compact)
        signal.signal(signal.SIGUSR1, _sigusr1_handler)

    def _reactivate_voice_compact(self):
        """Reactivate voice input on the compact voice window."""
        win = self.window
        if win and hasattr(win, '_mic_btn'):
            mic = win._mic_btn
            if mic.get_active():
                mic.set_active(False)
            mic.set_active(True)
        return False

def main():
    """Application entry point."""
    app = WidgetLoaderApp()
    return app.run(sys.argv)
if __name__ == '__main__':
    main()
